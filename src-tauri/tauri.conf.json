{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nevco 4770 Emulator",
  "version": "1.0.0",
  "identifier": "co.arcwire.nevco4770",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "node scripts/copy-frontend.mjs",
    "beforeBuildCommand": "node scripts/copy-frontend.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nevco 4770 Hockey Scoreboard Emulator",
        "width": 1180,
        "height": 980,
        "minWidth": 480,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© Arcwire",
    "category": "Utility",
    "shortDescription": "Nevco 4770 hockey scoreboard emulator",
    "longDescription": "A browser-free desktop emulator of the Nevco 4770 hockey scoreboard with the MPCW-7 hand controller."
  }
}
